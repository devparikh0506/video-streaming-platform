# Root env file consumed by docker-compose for ${VAR} substitution.
# Copy to .env (git-ignored) and fill in real values.

# LocalStack Pro / Team auth token. Required to start localstack/localstack-pro
# and to attach the container to the LocalStack Cloud dashboard.
# Get it from https://app.localstack.cloud/workspace/auth-token
LOCALSTACK_AUTH_TOKEN=ls-your-token-here

# Number of concurrent transcode jobs per worker container (Celery prefork
# pool size). Transcoding is CPU-bound and ffmpeg already uses all cores per
# job, so keep this low. Raise only if the host has spare cores. Default: 2.
CELERY_CONCURRENCY=10
