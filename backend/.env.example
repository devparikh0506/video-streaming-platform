APP_NAME="Video Streaming Platform API"
ENVIRONMENT="development"
LOG_LEVEL="INFO"
API_PREFIX="/api"
BACKEND_CORS_ORIGINS="http://localhost:5173"
DATA_DIR="../data"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# AWS / S3 — LOCAL DEV (LocalStack) values shown.
# Non-secret operational defaults live in code; override only if needed.
AWS_ENDPOINT_URL="http://localhost:4566"
AWS_PUBLIC_ENDPOINT_URL="http://localhost:4566"
AWS_DEFAULT_REGION="us-east-1"
S3_BUCKET="videos"
S3_USE_PATH_STYLE="true"

# Secrets — REQUIRED. App fails fast at startup if these are missing.
# For LocalStack the conventional dummy values are "test"/"test".
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"

# --- PRODUCTION (real AWS) ---
# To target a real AWS account instead of LocalStack, set:
#   AWS_ENDPOINT_URL=""            # empty -> boto3 uses real AWS endpoints
#   AWS_PUBLIC_ENDPOINT_URL=""     # empty -> same real endpoint for presigning
#   AWS_DEFAULT_REGION="<your-region>"
#   S3_BUCKET="<your-real-bucket>"
#   S3_USE_PATH_STYLE="false"      # real S3 prefers virtual-hosted style
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY = your real IAM credentials
# No application code changes are required.
